# Required for the OpenAI solver (captcha method B) and the login bot.
OPENAI_API_KEY=sk-...

# Login bot credentials (your own BLS account).
BLS_EMAIL=you@example.com
BLS_PASSWORD=your-password

# Telegram notifier (optional). If unset, notifications are disabled.
# Create a bot via @BotFather to get the token; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Second Telegram bot for run summaries AND errors/bot-blocks (optional).
# If unset, no summary/error messages are sent. Slot alerts still use the main bot above.
TELEGRAM_SUMMARY_BOT_TOKEN=123456:ABC-your-summary-bot-token
TELEGRAM_SUMMARY_CHAT_ID=123456789

# Timezone for readable timestamps in messages/logs. On EC2 the default is UTC;
# set this to see local time. e.g. Asia/Dubai, Europe/Madrid.
# TZ=Asia/Dubai

# Optional proxy for ALL browser traffic (e.g. route EC2 out via your home IP
# over an SSH SOCKS tunnel). Leave unset for a direct connection.
# PROXY_URL=socks5://localhost:1080
