{
  "name": "captcha-toolkit",
  "version": "0.1.0",
  "description": "Future-proof, feature-modular toolkit. First feature: solve grid captchas via OCR or OpenAI and output the target number and matching boxes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "solve": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "dump": "tsx src/debug-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "captcha",
    "ocr",
    "openai",
    "tesseract"
  ],
  "license": "MIT",
  "dependencies": {
    "openai": "^4.67.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
